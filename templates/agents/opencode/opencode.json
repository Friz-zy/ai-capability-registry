{
  "$schema": "https://opencode.ai/config.json",

  "username": "developer",

  "model": "anthropic/claude-sonnet-4-20250514",
  "small_model": "anthropic/claude-haiku-4-20250514",

  "default_agent": "code",

  "shell": "/bin/zsh",
  "logLevel": "INFO",

  "share": "manual",
  "autoupdate": true,
  "snapshot": true,

  "instructions": ["AGENTS.md", "docs/style.md"],

  "skills": {
    "paths": [".opencode/skills", "/absolute/path/to/skills"],
    "urls": ["https://example.com/.well-known/skills/"]
  },

  "references": {
    "docs": {
      "path": "../docs",
      "description": "Use for product behavior and documentation conventions"
    },
    "sdk": {
      "repository": "owner/sdk",
      "branch": "main",
      "description": "Use for SDK implementation details",
      "hidden": true
    }
  },

  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "anthropic/claude-haiku-4-20250514",
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "docs-writer": {
      "description": "Specialized for writing and editing technical documentation",
      "mode": "primary",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "{file:./prompts/docs-writer.txt}",
      "permission": {
        "edit": {
          "*.md": "allow",
          "*": "deny"
        },
        "bash": "deny"
      }
    }
  },

  "command": {
    "deploy": {
      "description": "Deploy the current project to staging",
      "prompt": "Deploy the project following the deployment checklist in docs/deploy.md"
    }
  },

  "provider": {
    "anthropic": {
      "options": {
        "apiKey": "env:ANTHROPIC_API_KEY"
      }
    },
    "openai": {
      "options": {
        "apiKey": "env:OPENAI_API_KEY"
      }
    }
  },
  "disabled_providers": [],
  "enabled_providers": ["anthropic", "openai"],

  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/workspace"],
      "enabled": true,
      "env": {
        "NODE_ENV": "production"
      }
    },
    "github-api": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "env:GITHUB_TOKEN"
      }
    },
    "remote-api": {
      "type": "remote",
      "url": "https://api.example.com/mcp",
      "headers": {
        "Authorization": "Bearer env:API_TOKEN"
      },
      "enabled": true
    }
  },

  "plugin": [
    "opencode-gemini-auth",
    "./local-plugin.ts"
  ],

  "permission": {
    "edit": "allow",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git commit *": "ask",
      "git push *": "deny",
      "npm test *": "allow",
      "npm run *": "allow",
      "grep *": "allow"
    },
    "skill": {
      "*": "allow",
      "internal-*": "deny",
      "experimental-*": "ask"
    }
  },

  "formatter": false,
  "lsp": true,

  "experimental": {
    "primary_tools": ["edit"],
    "mcp_timeout": 30000
  },

  "tool_output": {
    "max_lines": 200,
    "max_bytes": 8192
  },

  "compaction": {
    "auto": true,
    "tail_turns": 15
  }
}