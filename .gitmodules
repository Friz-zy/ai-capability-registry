# External capability sources are intentionally pinned as submodules when added.
# MVP starts registry-first; run scripts/update-submodules.sh after adding sources.
[submodule "external/anthropic-skills"]
	path = external/anthropic-skills
	url = https://github.com/anthropics/skills
[submodule "external/anthropic-claude-plugins-official"]
	path = external/anthropic-claude-plugins-official
	url = https://github.com/anthropics/claude-plugins-official
[submodule "external/anthropic-knowledge-work-plugins"]
	path = external/anthropic-knowledge-work-plugins
	url = https://github.com/anthropics/knowledge-work-plugins
[submodule "external/openai-skills"]
	path = external/openai-skills
	url = https://github.com/openai/skills
[submodule "external/agentskills-spec"]
	path = external/agentskills-spec
	url = https://github.com/agentskills/agentskills
[submodule "external/trailofbits-skills"]
	path = external/trailofbits-skills
	url = https://github.com/trailofbits/skills
[submodule "external/trailofbits-skills-curated"]
	path = external/trailofbits-skills-curated
	url = https://github.com/trailofbits/skills-curated
[submodule "external/kilo-marketplace-skills"]
	path = external/kilo-marketplace-skills
	url = https://github.com/Kilo-Org/kilo-marketplace
